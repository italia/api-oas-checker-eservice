# E-Service Configuration
ESERVICE_HOST=0.0.0.0
ESERVICE_PORT=8000

# OpenAPI Server URL (used in Swagger UI and openapi.yaml)
OPENAPI_SERVER_URL=http://localhost:8000
# Base URL for RFC 9457 Problem Details documentation (links in OpenAPI responses)
# PROBLEM_BASE_URL=https://github.com/italia/api-oas-checker-eservice/blob/main/docs/PROBLEMS.md#

# Database Configuration (PostgreSQL)
# Format: postgresql://username:password@hostname:port/database_name
DATABASE_URL=postgresql://oaschecker:oaschecker@localhost:5432/oaschecker

# Function Configuration
FUNCTION_TYPE=mock  # Options: mock | azure | azure-local
FUNCTION_URL=http://localhost:8001  # mock: 8001 | azure-local: 7071 | azure: https://...

# Azure Function Key (only if FUNCTION_TYPE=azure)
# AZURE_FUNCTION_KEY=your-function-key-here

# Callback Configuration
# CALLBACK_BASE_URL=http://localhost:8000  # Auto-generated if not set

# Ruleset Configuration
RULESET_REPO=italia/api-oas-checker-rules
RULESET_VERSION=latest
RULESET_PATH=./data/rulesets
RULESET_AUTO_UPDATE=true

# Security
JWT_ENABLED=false
CALLBACK_SECRET=dev-secret-change-in-production
HMAC_ENABLED=false

# Rate Limiting
RATE_LIMIT_ENABLED=false